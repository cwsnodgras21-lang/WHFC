# Supabase — create a new project at https://supabase.com/dashboard
# API settings: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Server-only. NEVER expose to the browser or commit real values.
# Used only for documented admin/bootstrap scripts — not for normal inventory RPCs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: absolute origin embedded in printed location QR codes.
# Falls back to the request origin when unset. Set in production so codes
# printed from a preview deploy still point at the real app.
NEXT_PUBLIC_SITE_URL=https://whfc-inventory.vercel.app
